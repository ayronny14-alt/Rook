{
  "name": "rook",
  "version": "0.1.5",
  "description": "Rook AI Assistant – Electron frontend",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:backend": "node scripts/build-backend.js",
    "prebuild": "npm run build:backend",
    "build": "electron-builder build --win",
    "build:dir": "electron-builder build --win dir",
    "prerelease": "npm run build:backend",
    "release": "electron-builder build --win --publish always",
    "release:draft": "electron-builder build --win --publish onTagOrDraft"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.svrn.rook",
    "productName": "Rook",
    "copyright": "Copyright © 2025",
    "beforeBuild": "scripts/verify-backend.js",
    "files": [
      "**/*",
      "!**/.env",
      "!**/.env.*",
      "!**/*.map",
      "!**/node_modules/.cache/**",
      "!**/node_modules/**/{CHANGELOG.md,README.md,readme.md,CONTRIBUTING.md,LICENSE,license,*.d.ts,*.md,.github,.npmignore,tsconfig*,test,tests,__tests__,example,examples,docs,doc}"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "../backend/target/release/rook.exe",
        "to": "backend/rook.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Rook-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rook",
      "menuCategory": "Rook",
      "uninstallDisplayName": "Rook",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "include": "scripts/installer-hooks.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "ayronny14-alt",
      "repo": "Rook",
      "releaseType": "release"
    },
    "directories": {
      "output": "../dist"
    }
  }
}
